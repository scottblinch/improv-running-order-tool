{
  "name": "improv-running-order-tool",
  "version": "1.0.0",
  "description": "Build and manage improv show lineups, cast assignments, and print-ready show sheets. Client-side only; data stays in your browser.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22"
  },
  "license": "GPL-2.0-only",
  "author": "Scott Blinch",
  "homepage": "https://scottblinch.github.io/improv-running-order-tool/",
  "bugs": {
    "url": "https://github.com/scottblinch/improv-running-order-tool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottblinch/improv-running-order-tool.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && BROWSERSLIST_ENV=production vite build",
    "build:pages": "tsc -b && GITHUB_PAGES=true BROWSERSLIST_ENV=production vite build",
    "check:pages": "pnpm lint && pnpm format:check && pnpm audit && pnpm test && pnpm build:pages",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "pnpm lint:fix && pnpm format",
    "test": "vitest run",
    "audit": "pnpm audit --audit-level moderate",
    "generate:pwa-assets": "pwa-assets-generator --config pwa-assets.config.ts",
    "generate:og-image": "node scripts/generate-og-image.mjs",
    "check": "pnpm lint && pnpm format:check && pnpm audit && pnpm test && pnpm build",
    "check:precommit": "pnpm lint && pnpm format:check && pnpm test",
    "preview": "vite preview",
    "preview:pages": "pnpm build:pages && vite preview --base /improv-running-order-tool/",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.0",
    "fflate": "^0.8.3",
    "i18next": "^26.2.0",
    "i18next-icu": "^2.4.3",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.11.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.1"
  }
}
