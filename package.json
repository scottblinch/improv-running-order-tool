{
  "name": "improv-running-order-tool",
  "version": "1.0.0",
  "description": "A simple improv running order tool",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "license": "GPL-2.0-only",
  "author": "Scott Blinch",
  "homepage": "https://scottblinch.github.io/improv-running-order-tool/",
  "bugs": {
    "url": "https://github.com/scottblinch/improv-running-order-tool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottblinch/improv-running-order-tool.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && BROWSERSLIST_ENV=production vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run lint:fix && npm run format",
    "check": "npm run lint && npm run format:check && npm run build",
    "preview": "vite preview",
    "preview:pages": "GITHUB_PAGES=true BROWSERSLIST_ENV=production npm run build && vite preview --base /improv-running-order-tool/"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
